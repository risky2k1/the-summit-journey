// Summit Journey — khớp `.cursor/docs/database.md`
// Connection URL cho engine migrate nằm trong `prisma.config.ts` (ưu tiên `DIRECT_URL`).

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventType {
  normal
  encounter
  ending
}

enum PlayerStat {
  tu_vi
  karma
  luck
  physical
}

/// Một bản campaign (ví dụ seed từ `.n8n/result.json`).
model Campaign {
  id              Int       @id @default(autoincrement())
  slug            String    @unique @default("main")
  totalChapters   Int       @map("total_chapters")
  totalEvents     Int       @map("total_events")
  /// `events.ref` của màn mở đầu (chương 1, event đầu tiên).
  startEventRef   String    @map("start_event_ref")

  chapters Chapter[]

  @@map("campaigns")
}

model Chapter {
  id             Int    @id @default(autoincrement())
  campaignId     Int    @map("campaign_id")
  chapterIndex   Int    @map("chapter_index")
  title          String @db.Text
  summaryOneLine String @map("summary_one_line") @db.Text

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  events   Event[]

  @@unique([campaignId, chapterIndex])
  @@map("chapters")
}

model Event {
  id          Int       @id @default(autoincrement())
  /// Slug ổn định từ pipeline n8n / AI (`c01_mo_dau`, …); map `choices.next_event_ref` khi seed.
  ref         String?   @unique
  title       String
  description String    @db.Text
  type        EventType
  isActive    Boolean   @default(true) @map("is_active")
  /// Trọng số khi engine chọn event ngẫu nhiên (`findNextEventId`). Tối thiểu hiệu dụng = 1.
  pickWeight  Int       @default(1) @map("pick_weight")
  chapterId   Int?      @map("chapter_id")
  chapter     Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  choicesFromHere Choice[]     @relation("EventChoices")
  choicesPointingHere Choice[] @relation("NextEvent")
  tags              EventTag[]
  runsAtCurrent     PlayerRun[] @relation("CurrentEvent")
  runHistoryEvents  RunHistory[]

  @@index([chapterId])
  @@map("events")
}

model Choice {
  id          Int     @id @default(autoincrement())
  eventId     Int     @map("event_id")
  content     String  @db.Text
  nextEventId Int?    @map("next_event_id")
  weight      Int     @default(1)

  event     Event    @relation("EventChoices", fields: [eventId], references: [id], onDelete: Cascade)
  nextEvent Event?   @relation("NextEvent", fields: [nextEventId], references: [id], onDelete: SetNull)
  effects   ChoiceEffect[]
  conditions ChoiceCondition[]
  runHistory RunHistory[]

  @@map("choices")
}

model ChoiceEffect {
  id       Int        @id @default(autoincrement())
  choiceId Int        @map("choice_id")
  stat     PlayerStat
  value    Int

  choice Choice @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  @@map("choice_effects")
}

model ChoiceCondition {
  id       Int        @id @default(autoincrement())
  choiceId Int        @map("choice_id")
  stat     PlayerStat
  /// Toán tử so sánh với stat người chơi: `>`, `<`, `=`
  operator String     @db.VarChar(2)
  value    Int

  choice Choice @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  @@map("choice_conditions")
}

model EventTag {
  id      Int    @id @default(autoincrement())
  eventId Int    @map("event_id")
  tag     String @db.Text

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, tag])
  @@map("event_tags")
}

model PlayerRun {
  id             Int     @id @default(autoincrement())
  /// Supabase Auth `auth.users.id`
  userId         String? @map("user_id") @db.Uuid
  playerName     String  @map("player_name") @db.VarChar(64)
  currentEventId Int?    @map("current_event_id")
  stats          Json    @default("{}")
  seed           String  @db.Text
  /// Nhận xét lão tu (OpenRouter), sinh sau khi tạo run — có thể null.
  characterCommentary String? @map("character_commentary") @db.Text

  currentEvent Event?       @relation("CurrentEvent", fields: [currentEventId], references: [id], onDelete: SetNull)
  history      RunHistory[]

  @@index([userId])
  @@map("player_runs")
}

model RunHistory {
  id       Int @id @default(autoincrement())
  runId    Int @map("run_id")
  eventId  Int @map("event_id")
  choiceId Int @map("choice_id")

  run    PlayerRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  event  Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  choice Choice    @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("run_history")
}

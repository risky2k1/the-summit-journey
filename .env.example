# Prisma — app/runtime: pooler (Supabase: POSTGRES_PRISMA_URL, port 6543 + pgbouncer)
DATABASE_URL="postgres://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true"
# Migrate / CLI: bắt buộc session/direct (port 5432). Trùng POSTGRES_URL_NON_POOLING — không dùng pooler cho migrate
DIRECT_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

